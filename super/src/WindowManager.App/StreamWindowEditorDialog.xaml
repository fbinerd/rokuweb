<Window x:Class="WindowManager.App.StreamWindowEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Janela"
        Width="520"
        Height="240"
        MinWidth="480"
        MinHeight="220"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Nickname da janela"
                   FontWeight="SemiBold" />
        <TextBox Grid.Row="1"
                 Margin="0,8,0,0"
                 Height="28"
                 VerticalContentAlignment="Center"
                 Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="Link da janela"
                   FontWeight="SemiBold" />
        <TextBox Grid.Row="3"
                 Margin="0,8,0,0"
                 Height="28"
                 VerticalContentAlignment="Center"
                 Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Width="90"
                    Height="28"
                    Margin="0,0,8,0"
                    Content="Cancelar"
                    IsCancel="True" />

            <Button Grid.Column="2"
                    Width="90"
                    Height="28"
                    Content="Salvar"
                    IsDefault="True"
                    Click="OnSaveClick" />
        </Grid>
    </Grid>
</Window>
