<Window x:Class="WindowManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Window Manager Broadcast"
        Width="1520"
        Height="1020"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.ColumnSpan="3" Margin="0,0,0,16">
            <TextBlock Text="Gerenciador de Janelas e Rotas"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Logs"
                        Width="90"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnOpenLogsClick" />
                <Button Content="Atualizar destinos"
                        Width="160"
                        Height="34"
                        Command="{Binding RefreshTargetsCommand}" />
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Perfil">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Width="80"
                                Height="34"
                                Content="Salvar"
                                Command="{Binding SaveProfileCommand}" />

                        <Button Grid.Column="2"
                                Margin="8,0,0,0"
                                Width="80"
                                Height="34"
                                Content="Carregar"
                                Command="{Binding LoadProfileCommand}" />

                        <Button Grid.Column="3"
                                Margin="8,0,0,0"
                                Width="80"
                                Height="34"
                                Content="Excluir"
                                Command="{Binding DeleteProfileCommand}" />

                        <ComboBox Grid.Row="1"
                                  Grid.ColumnSpan="4"
                                  Margin="0,12,0,0"
                                  Height="34"
                                  ItemsSource="{Binding AvailableProfiles}"
                                  SelectedItem="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Grid.Row="2" Grid.ColumnSpan="4" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding IsDefaultProfile, StringFormat=Perfil padrao ativo: {0}}" />

                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Width="140"
                                    Height="34"
                                    Content="Definir padrao"
                                    Command="{Binding SetDefaultProfileCommand}" />
                        </Grid>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Navegacao" Margin="0,12,0,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="3" Text="URL da janela selecionada" FontWeight="SemiBold" />

                        <TextBox Grid.Row="1"
                                 Grid.ColumnSpan="3"
                                 Margin="0,8,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding BrowserUrlInput, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,12,0,0"
                                Height="34"
                                Content="Criar janela"
                                Command="{Binding CreateWindowCommand}" />

                        <Button Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,12,0,0"
                                Height="34"
                                Content="Abrir URL"
                                Command="{Binding NavigateSelectedWindowCommand}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Atualizacoes" Margin="0,12,0,0">
                    <StackPanel Margin="12">
                        <CheckBox Content="Baixar e aplicar atualizacoes automaticamente ao iniciar"
                                  IsChecked="{Binding AutoUpdateEnabled, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding AppVersionStatus}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding LatestAvailableVersion, StringFormat=Release mais recente: {0}}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding UpdateStatusMessage}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#0F766E"
                                   Text="{Binding RecommendedUpdatePackageUrl}"
                                   TextWrapping="Wrap" />
                        <Button Margin="0,12,0,0"
                                Height="34"
                                Content="Buscar e baixar atualizacao"
                                Command="{Binding CheckAndDownloadUpdateCommand}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Publicacao WebRTC Local" Margin="0,12,0,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Configure como o servidor local vai aceitar conexoes. Cada janela publicada usa automaticamente o nickname dela como rota, por exemplo: http://192.168.1.20:8088/sala1"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="Porta do servidor" FontWeight="SemiBold" />
                        <TextBox Grid.Row="2"
                                 Margin="0,8,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding WebRtcServerPort, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="Modo de acesso" FontWeight="SemiBold" />
                        <ComboBox Grid.Row="4"
                                  Margin="0,8,0,0"
                                  Height="34"
                                  ItemsSource="{Binding WebRtcBindModes}"
                                  SelectedItem="{Binding WebRtcBindMode, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="5" Margin="0,12,0,0" Text="IP especifico" FontWeight="SemiBold" />
                        <TextBox Grid.Row="6"
                                 Margin="0,8,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding WebRtcSpecificIp, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="7"
                                   Margin="0,8,0,0"
                                   Foreground="DimGray"
                                   Text="Para acessar por outro IP, use Lan ou SpecificIp. No modo Lan, o servidor aceita acessos de outros IPs da rede."
                                   TextWrapping="Wrap" />

                        <CheckBox Grid.Row="8"
                                  Margin="0,12,0,0"
                                  Content="Publicar esta janela em rota local tipo WebRTC"
                                  IsChecked="{Binding SelectedWindow.IsWebRtcPublishingEnabled, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Row="9"
                                Margin="0,12,0,0"
                                Height="34"
                                Content="Atualizar rota publicada"
                                Command="{Binding PublishWebRtcCommand}" />

                        <TextBlock Grid.Row="10"
                                   Margin="0,12,0,0"
                                   Text="{Binding SelectedWindow.PublishedWebRtcUrl}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Resolucao" Margin="0,12,0,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="3" Text="{Binding SelectedTargetNativeResolution}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0" Text="Renderizacao do navegador" FontWeight="SemiBold" />
                        <ComboBox Grid.Row="2"
                                  Grid.ColumnSpan="3"
                                  Margin="0,8,0,0"
                                  Height="34"
                                  ItemsSource="{Binding ResolutionModes}"
                                  SelectedItem="{Binding SelectedWindow.BrowserResolutionMode, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="0"
                                 Margin="0,8,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SelectedWindow.BrowserManualWidth, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="2"
                                 Margin="0,8,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SelectedWindow.BrowserManualHeight, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Margin="0,12,0,0" Text="Renderizacao da TV / saida" FontWeight="SemiBold" />
                        <ComboBox Grid.Row="5"
                                  Grid.ColumnSpan="3"
                                  Margin="0,8,0,0"
                                  Height="34"
                                  ItemsSource="{Binding ResolutionModes}"
                                  SelectedItem="{Binding SelectedWindow.TargetResolutionMode, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="6"
                                 Grid.Column="0"
                                 Margin="0,8,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SelectedWindow.TargetManualWidth, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="6"
                                 Grid.Column="2"
                                 Margin="0,8,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SelectedWindow.TargetManualHeight, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="#F3F4F6"
                        CornerRadius="8">
                    <TextBlock Text="{Binding PreviewSubtitle}" TextWrapping="Wrap" />
                </Border>

                <GroupBox Header="Descoberta de TVs" Margin="0,12,0,0">
                    <StackPanel Margin="8">
                        <TextBlock Text="Busca TVs na rede priorizando IPs historicos. Se o IP mudar, a reconciliacao usa MAC/ID unico e atualiza o endereco armazenado." TextWrapping="Wrap" />
                        <ListBox Margin="0,8,0,0"
                                 Height="220"
                                 ItemsSource="{Binding Targets}"
                                 SelectedItem="{Binding SelectedTarget}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Text="{Binding AddressSummary}"
                                                   Foreground="#334155" />
                                        <TextBlock Margin="0,1,0,0"
                                                   Text="{Binding MetadataSummary}"
                                                   Foreground="DimGray"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Height="34"
                                    Content="Marcar TV estatica"
                                    Command="{Binding MarkSelectedTargetStaticCommand}" />
                            <Button Grid.Column="2"
                                    Height="34"
                                    Content="Excluir TV"
                                    Command="{Binding DeleteSelectedTargetCommand}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Paineis Estaticos" Margin="0,12,0,0">
                    <StackPanel Margin="8">
                        <ListBox Height="180"
                                 ItemsSource="{Binding StaticPanels}"
                                 SelectedItem="{Binding SelectedStaticPanel}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,6">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DisplayName}" Foreground="DimGray" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Height="34"
                                    Content="Criar painel da TV"
                                    Command="{Binding CreateStaticPanelCommand}" />
                            <Button Grid.Column="2"
                                    Height="34"
                                    Content="Excluir painel"
                                    Command="{Binding DeleteSelectedPanelCommand}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <Button Margin="0,12,0,0"
                        Height="36"
                        Content="Transmitir janela selecionada"
                        Command="{Binding AssignSelectedWindowCommand}" />

                <TextBlock Margin="0,12,0,0"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <GroupBox Grid.Row="1" Grid.Column="2" Header="Painel Simultaneo">
            <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="PreviewPanel" ItemWidth="360" ItemHeight="260" />
            </ScrollViewer>
        </GroupBox>

        <TextBlock Grid.Row="2"
                   Grid.ColumnSpan="3"
                   Margin="0,16,0,0"
                   Foreground="DimGray"
                   Text="TVs podem ser marcadas como estaticas, paines voltados a elas podem ser criados e perfis, TVs e paineis podem ser excluidos diretamente pela interface." />
    </Grid>
</Window>
