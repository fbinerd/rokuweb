<Window x:Class="WindowManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Window Manager Broadcast"
        Width="1520"
        Height="1020"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.ColumnSpan="3" Margin="0,0,0,16">
            <TextBlock Text="Gerenciador de Janelas e Rotas"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Ligar TVs e abrir app"
                        Width="160"
                        Height="34"
                        Margin="0,0,8,0"
                        Command="{Binding PowerOnConnectedRokusCommand}" />
                <Button Content="Desligar todas as TVs"
                        Width="160"
                        Height="34"
                        Margin="0,0,8,0"
                        Command="{Binding PowerOffConnectedRokusCommand}" />
                <Button Content="Encerrar app"
                        Width="120"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnExitApplicationClick" />
                <Button Content="Logs"
                        Width="90"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnOpenLogsClick" />
                <Button Content="Atualizar destinos"
                        Width="160"
                        Height="34"
                        Command="{Binding RefreshTargetsCommand}" />
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Base de configuracao">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="4"
                                   Text="Cada perfil representa uma base de configuracao independente. O perfil de fabrica e o 'default'. Todas as alteracoes do programa ficam salvas no perfil selecionado."
                                   TextWrapping="Wrap"
                                   Foreground="#334155" />

                        <TextBox Grid.Row="1"
                                 Grid.Column="0"
                                 Margin="0,10,0,0"
                                 Height="28"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Margin="8,10,0,0"
                                Width="68"
                                Height="28"
                                Content="Salvar"
                                Command="{Binding SaveProfileCommand}" />

                        <Button Grid.Row="1"
                                Grid.Column="2"
                                Margin="8,10,0,0"
                                Width="72"
                                Height="28"
                                Content="Carregar"
                                Command="{Binding LoadProfileCommand}" />

                        <Button Grid.Row="1"
                                Grid.Column="3"
                                Margin="8,10,0,0"
                                Width="64"
                                Height="28"
                                Content="Excluir"
                                Command="{Binding DeleteProfileCommand}" />

                        <ComboBox Grid.Row="2"
                                  Grid.ColumnSpan="4"
                                  Margin="0,10,0,0"
                                  Height="28"
                                  ItemsSource="{Binding AvailableProfiles}"
                                  SelectedItem="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Grid.Row="3" Grid.ColumnSpan="4" Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="{Binding IsDefaultProfile, StringFormat=Perfil padrao ativo: {0}}" />

                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Width="108"
                                    Height="28"
                                    Content="Definir padrao"
                                    Command="{Binding SetDefaultProfileCommand}" />

                            <Button Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,10,0,0"
                                    Height="28"
                                    Content="Salvar backup"
                                    Click="OnExportApplicationDataClick" />

                            <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="8,10,0,0"
                                    Width="118"
                                    Height="28"
                                    Content="Restaurar backup"
                                    Click="OnImportApplicationDataClick" />

                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="8,10,0,0"
                                    Width="104"
                                    Height="28"
                                    Content="Resetar base"
                                    Click="OnResetApplicationDataClick" />
                        </Grid>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Setup TV" Margin="0,12,0,0">
                    <StackPanel Margin="12">
                        <TextBlock Text="Crie um perfil de TV escolhendo a TV base do perfil ou inserindo um IP manual quando ela nao aparecer."
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Width="40"
                                    Height="34"
                                    FontSize="18"
                                    Content="+"
                                    Click="OnOpenTvProfileSetupClick" />
                            <Button Grid.Column="2"
                                    Width="40"
                                    Height="34"
                                    FontSize="18"
                                    Content="-"
                                    Command="{Binding DeleteSelectedTvProfileCommand}" />
                        </Grid>
                        <ListBox Margin="0,12,0,0"
                                 Height="180"
                                 ItemsSource="{Binding TvProfiles}"
                                 SelectedItem="{Binding SelectedTvProfile}"
                                 MouseDoubleClick="OnEditSelectedTvProfileDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Text="{Binding PrimaryDisplayName, StringFormat=TV base: {0}}"
                                                   Foreground="#334155" />
                                        <TextBlock Margin="0,1,0,0"
                                                   Text="{Binding PrimaryNetworkAddress, StringFormat=IP: {0}}"
                                                   Foreground="DimGray" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Setup Stream" Margin="0,12,0,0">
                    <StackPanel Margin="12">
                        <TextBlock Text="Crie um stream de janelas CEF com nickname, escolha o perfil de TV de destino e defina as janelas 1, 2, 3..."
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Width="40"
                                    Height="28"
                                    FontSize="18"
                                    Content="+"
                                    Click="OnOpenWindowProfileSetupClick" />
                            <Button Grid.Column="2"
                                    Width="40"
                                    Height="28"
                                    FontSize="18"
                                    Content="-"
                                    Command="{Binding DeleteSelectedWindowProfileCommand}" />
                        </Grid>
                        <ListBox Margin="0,12,0,0"
                                 x:Name="StreamProfilesListBox"
                                 Height="180"
                                 ItemsSource="{Binding WindowProfiles}"
                                 SelectedItem="{Binding SelectedWindowProfile}"
                                 MouseDoubleClick="OnEditSelectedWindowProfileDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Text="{Binding Windows.Count, StringFormat=Janelas no stream: {0}}"
                                                   Foreground="#334155" />
                                        <TextBlock Margin="0,1,0,0"
                                                   Text="{Binding AssignedTvProfileName, StringFormat=Perfil de TV: {0}}"
                                                   Foreground="DimGray" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Atualizacoes" Margin="0,12,0,0">
                    <StackPanel Margin="12">
                        <CheckBox Content="Baixar e aplicar atualizacoes automaticamente ao iniciar"
                                  IsChecked="{Binding AutoUpdateEnabled, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding IsAutomaticUpdateToggleEnabled}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Canal de atualizacao"
                                   FontWeight="SemiBold" />
                        <ComboBox Margin="0,8,0,0"
                                  Height="34"
                                  ItemsSource="{Binding UpdateChannels}"
                                  SelectedItem="{Binding SelectedUpdateChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding AppVersionStatus}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding LatestAvailableVersion, StringFormat=Release mais recente: {0}}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding UpdateStatusMessage}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#0F766E"
                                   Text="{Binding RecommendedUpdatePackageUrl}"
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Height="34"
                                    Content="Buscar atualizacoes"
                                    Command="{Binding SearchUpdatesCommand}" />
                            <Button Grid.Column="2"
                                    Height="34"
                                    Content="Instalar atualizacao"
                                    Command="{Binding InstallUpdateCommand}" />
                        </Grid>
                        <Button Margin="0,12,0,0"
                                Height="34"
                                Content="Migrar para build remota"
                                Command="{Binding MigrateToRemoteBuildCommand}"
                                Visibility="{Binding IsLocalDevelopmentBuild, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Margin="0,12,0,0"
                                Height="34"
                                Content="Atualizar TVs conectadas"
                                Command="{Binding UpdateConnectedTvsCommand}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Publicacao WebRTC Local" Margin="0,12,0,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Configure como o servidor local vai aceitar conexoes. Cada janela publicada usa automaticamente o nickname dela como rota, por exemplo: http://192.168.1.20:8088/sala1"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="Porta do servidor" FontWeight="SemiBold" />
                        <TextBox Grid.Row="2"
                                 Margin="0,8,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding WebRtcServerPort, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="Modo de acesso" FontWeight="SemiBold" />
                        <ComboBox Grid.Row="4"
                                  Margin="0,8,0,0"
                                  Height="34"
                                  ItemsSource="{Binding WebRtcBindModes}"
                                  SelectedItem="{Binding WebRtcBindMode, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="5" Margin="0,12,0,0" Text="IP especifico" FontWeight="SemiBold" />
                        <TextBox Grid.Row="6"
                                 Margin="0,8,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding WebRtcSpecificIp, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="7"
                                   Margin="0,8,0,0"
                                   Foreground="DimGray"
                                   Text="Para acessar por outro IP, use Lan ou SpecificIp. No modo Lan, o servidor aceita acessos de outros IPs da rede."
                                   TextWrapping="Wrap" />

                        <CheckBox Grid.Row="8"
                                  Margin="0,12,0,0"
                                  Content="Publicar esta janela em rota local tipo WebRTC"
                                  IsChecked="{Binding SelectedWindow.IsWebRtcPublishingEnabled, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Row="9"
                                Margin="0,12,0,0"
                                Height="34"
                                Content="Atualizar rota publicada"
                                Command="{Binding PublishWebRtcCommand}" />

                        <TextBlock Grid.Row="10"
                                   Margin="0,12,0,0"
                                   Text="{Binding SelectedWindow.PublishedWebRtcUrl}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>

                <TextBlock Margin="0,12,0,0"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Grid.Column="2">
            <GroupBox Header="Streams">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="StreamPreviewSectionsHost" />
                </ScrollViewer>
            </GroupBox>

            <Border x:Name="ExpandedPreviewOverlay"
                    Visibility="Collapsed"
                    Background="#CC0F172A"
                    CornerRadius="12"
                    Margin="8"
                    Panel.ZIndex="10">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ExpandedPreviewTitle"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Width="120"
                                Height="34"
                                Margin="12,0,0,0"
                                Content="Fechar"
                                Click="OnCloseExpandedPreviewClick" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,16,0,0"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1">
                        <Border x:Name="ExpandedPreviewHost"
                                Margin="12"
                                Background="#F8FAFC"
                                CornerRadius="8"
                                Focusable="True"
                                PreviewMouseMove="OnExpandedPreviewMouseMove"
                                PreviewMouseLeftButtonDown="OnExpandedPreviewMouseLeftButtonDown"
                                PreviewKeyDown="OnExpandedPreviewKeyDown"
                                PreviewTextInput="OnExpandedPreviewTextInput">
                            <Image x:Name="ExpandedPreviewImage"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True" />
                        </Border>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Grid.ColumnSpan="3"
                   Margin="0,16,0,0"
                   Foreground="DimGray"
                   Text="TVs podem ser marcadas como estaticas, paines voltados a elas podem ser criados e perfis, TVs e paineis podem ser excluidos diretamente pela interface." />
    </Grid>
</Window>
