<Window x:Class="WindowManager.App.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Carregando dependências..." Height="340" Width="480" WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True" AllowsTransparency="True" Background="Transparent">
    <Border CornerRadius="12" Background="#FF222831" Padding="24" BorderBrush="#FF393E46" BorderThickness="2">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="StatusText" Text="Verificando dependências..." Foreground="White" FontSize="18" Margin="0,0,0,16" HorizontalAlignment="Center"/>
            <Grid x:Name="ProgressContainer" Width="400" Height="24" Visibility="Collapsed">
                <ProgressBar x:Name="ProgressBar" Height="24" Width="400" Minimum="0" Maximum="100" Value="0"/>
                <Border x:Name="ProgressDetailsHost" Background="#88000000" CornerRadius="8" Padding="8,1" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False">
                    <Grid>
                        <TextBlock x:Name="ProgressDetailsShadowText" Text="" Foreground="#CC000000" FontSize="12" FontWeight="Bold" TextAlignment="Center" Margin="1,1,0,0"/>
                        <TextBlock x:Name="ProgressDetailsText" Text="" Foreground="#FFFDF6DA" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
            <StackPanel Margin="0,12,0,0" HorizontalAlignment="Center">
                <TextBlock x:Name="InstalledVersionText" Text="Versão instalada: -" Foreground="White" FontSize="14" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                <TextBlock x:Name="RemoteVersionText" Text="Versão disponível: -" Foreground="White" FontSize="14" Margin="0,0,0,8" HorizontalAlignment="Center"/>
            </StackPanel>
            <ComboBox x:Name="ChannelComboBox" Width="180" Margin="0,16,0,0" HorizontalAlignment="Center"/>
            <StackPanel Orientation="Vertical" Margin="0,8,0,0" HorizontalAlignment="Center">
                <CheckBox x:Name="AutoUpdateCheckBox" Content="Não perguntar e atualizar automaticamente" Foreground="White" Margin="0,8,0,0" VerticalAlignment="Center"/>
                <CheckBox x:Name="SetDefaultBranchCheckBox" Content="Marcar branch atual como default" Foreground="White" Margin="0,8,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <Button x:Name="OkButton" Content="OK" Width="180" Height="32" Margin="0,24,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
