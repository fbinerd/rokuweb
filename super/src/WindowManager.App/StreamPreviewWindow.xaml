<Window x:Class="WindowManager.App.StreamPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visualizacao Expandida"
        Width="1100"
        Height="760"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        KeyDown="OnKeyDown"
        TextInput="OnTextInput">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="AddressTextBlock"
                   Foreground="DimGray"
                   TextWrapping="Wrap" />

        <Border x:Name="PreviewHost"
                Grid.Row="1"
                Margin="0,10,0,0"
                Focusable="True"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Background="#F8FAFC"
                MouseMove="OnPreviewMouseMove"
                MouseLeftButtonDown="OnPreviewMouseLeftButtonDown">
            <Grid>
                <Image x:Name="PreviewImage"
                       Stretch="Uniform" />
                <TextBlock x:Name="FallbackTextBlock"
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="DimGray"
                           TextWrapping="Wrap"
                           Text="Nenhuma pre-visualizacao disponivel." />
            </Grid>
        </Border>
    </Grid>
</Window>
