<Window x:Class="WindowManager.App.WindowProfileSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Setup Stream"
        Width="900"
        Height="640"
        MinWidth="820"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Defina o nickname do stream, selecione o perfil de TV de destino e monte as janelas do stream."
                   TextWrapping="Wrap" />

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                       Grid.ColumnSpan="3"
                       Text="Nickname do stream"
                       FontWeight="SemiBold" />
            <TextBox Grid.Row="1"
                     Grid.ColumnSpan="3"
                     Margin="0,8,0,0"
                     Height="28"
                     VerticalContentAlignment="Center"
                     Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="2"
                       Grid.ColumnSpan="3"
                       Margin="0,12,0,0"
                       Text="Perfil de TV para transmitir"
                       FontWeight="SemiBold" />
            <ComboBox Grid.Row="3"
                      Grid.ColumnSpan="3"
                      Margin="0,8,0,0"
                      Height="28"
                      ItemsSource="{Binding AvailableTvProfiles}"
                      SelectedItem="{Binding SelectedTvProfile}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Grid Grid.Row="4" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="92"
                        Height="28"
                        Content="Adicionar"
                        Click="OnAddWindowClick" />

                <Button Grid.Column="2"
                        Width="80"
                        Height="28"
                        Content="Editar"
                        Click="OnEditSelectedWindowClick" />

                <Button Grid.Column="4"
                        Width="92"
                        Height="28"
                        Content="Excluir"
                        Click="OnRemoveWindowClick" />
            </Grid>

            <GroupBox Grid.Row="5"
                      Grid.Column="0"
                      Margin="0,12,0,0"
                      Header="Janelas do stream">
                <ListView Margin="8"
                          ItemsSource="{Binding Windows}"
                          SelectedItem="{Binding SelectedWindow}"
                          MouseDoubleClick="OnWindowsListDoubleClick"
                          SelectionChanged="OnWindowsSelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#"
                                            Width="44"
                                            DisplayMemberBinding="{Binding NumberLabel}" />
                            <GridViewColumn Header="Janela"
                                            Width="180"
                                            DisplayMemberBinding="{Binding Nickname}" />
                            <GridViewColumn Header="Link"
                                            Width="240">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock TextTrimming="CharacterEllipsis">
                                            <Hyperlink Click="OnPreviewWindowClick"
                                                       Tag="{Binding}">
                                                <Run Text="{Binding Url}" />
                                            </Hyperlink>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <GroupBox Grid.Row="5"
                      Grid.Column="2"
                      Margin="0,12,0,0"
                      Header="Pre-visualizacao">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="PreviewAddressText"
                               Foreground="DimGray"
                               Text="Selecione uma janela ou clique no link para visualizar."
                               TextWrapping="Wrap" />

                    <Border Grid.Row="1"
                            Margin="0,8,0,0"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="6"
                            MouseLeftButtonDown="OnPreviewBorderMouseLeftButtonDown">
                        <Grid Background="#F8FAFC">
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform" />
                            <TextBlock x:Name="PreviewFallbackText"
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="DimGray"
                                       TextWrapping="Wrap"
                                       Text="Pre-visualizacao CEF indisponivel nesta maquina." />
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Width="110"
                    Height="28"
                    Margin="0,0,8,0"
                    Content="Excluir janela"
                    Click="OnRemoveWindowClick" />

            <Button Grid.Column="2"
                    Width="90"
                    Height="28"
                    Margin="0,0,8,0"
                    Content="Cancelar"
                    IsCancel="True" />

            <Button Grid.Column="3"
                    Width="90"
                    Height="28"
                    Content="Concluir"
                    IsDefault="True"
                    Click="OnSaveClick" />
        </Grid>
    </Grid>
</Window>
